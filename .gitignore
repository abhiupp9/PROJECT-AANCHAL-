# ─── Root-level .gitignore for PROJECT-AANCHAL- ───────────────────────────────

# Environment secrets — NEVER commit these
server/.env
.env
.env.local
.env.*.local

# Node modules
node_modules/
server/node_modules/
client/node_modules/

# Build outputs
client/dist/
client/dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# OS files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite temp
*.local
