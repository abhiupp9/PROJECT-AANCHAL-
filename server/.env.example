PORT=5000

# Supabase Configuration
# Go to your Supabase Project Settings > API to retrieve these credentials.
# For server-side operations, it is recommended to use the service_role key to bypass Row Level Security (RLS), 
# or configure RLS policies properly and use the anon public key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-api-key
